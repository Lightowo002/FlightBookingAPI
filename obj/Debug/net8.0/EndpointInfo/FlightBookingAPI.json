{
  "openapi": "3.0.1",
  "info": {
    "title": "FlightBookingAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/auth/registro": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Usuario"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Usuario"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Usuario"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/google": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleLoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleLoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/boletos": {
      "post": {
        "tags": [
          "Boletos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearBoletoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearBoletoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CrearBoletoRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/boletos/usuario/{usuarioId}": {
      "get": {
        "tags": [
          "Boletos"
        ],
        "parameters": [
          {
            "name": "usuarioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/boletos/vuelo/{vueloId}/asientos-ocupados": {
      "get": {
        "tags": [
          "Boletos"
        ],
        "parameters": [
          {
            "name": "vueloId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/boletos/{codigoReserva}": {
      "get": {
        "tags": [
          "Boletos"
        ],
        "parameters": [
          {
            "name": "codigoReserva",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vuelos": {
      "get": {
        "tags": [
          "Vuelos"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vuelos/buscar": {
      "get": {
        "tags": [
          "Vuelos"
        ],
        "parameters": [
          {
            "name": "origen",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destino",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fecha",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pasajeros",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vuelos/{id}": {
      "get": {
        "tags": [
          "Vuelos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CrearBoletoRequest": {
        "type": "object",
        "properties": {
          "usuarioId": {
            "type": "string",
            "nullable": true
          },
          "vueloId": {
            "type": "string",
            "nullable": true
          },
          "pasajeros": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PasajeroRequest"
            },
            "nullable": true
          },
          "asientos": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "clases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "montoTotal": {
            "type": "number",
            "format": "double"
          },
          "moneda": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "properties": {
          "correo": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GoogleLoginRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "contraseña",
          "correo"
        ],
        "type": "object",
        "properties": {
          "correo": {
            "minLength": 1,
            "type": "string"
          },
          "contraseña": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PasajeroRequest": {
        "type": "object",
        "properties": {
          "nombres": {
            "type": "string",
            "nullable": true
          },
          "documento": {
            "type": "string",
            "nullable": true
          },
          "correo": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          },
          "nuevaContraseña": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Usuario": {
        "required": [
          "apellidos",
          "contraseña",
          "correo",
          "nombres",
          "numeroDocumento",
          "telefono",
          "tipoDocumento"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "nombres": {
            "minLength": 1,
            "type": "string"
          },
          "apellidos": {
            "minLength": 1,
            "type": "string"
          },
          "tipoDocumento": {
            "minLength": 1,
            "pattern": "^(DNI|CE)$",
            "type": "string"
          },
          "numeroDocumento": {
            "minLength": 1,
            "type": "string"
          },
          "correo": {
            "minLength": 1,
            "pattern": "^([\\w\\.\\-]+)@([\\w\\-]+)((\\.(\\w){2,3})+)$",
            "type": "string"
          },
          "telefono": {
            "minLength": 1,
            "pattern": "^9[0-9]{8}$",
            "type": "string"
          },
          "contraseña": {
            "minLength": 1,
            "type": "string"
          },
          "rol": {
            "type": "string",
            "nullable": true
          },
          "fechaRegistro": {
            "type": "string",
            "format": "date-time"
          },
          "resetToken": {
            "type": "string",
            "nullable": true
          },
          "resetTokenExpira": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}